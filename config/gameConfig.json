  "collision": {
    "description": "碰撞检测使用判定框(hitbox)而非视觉框(visual box)。判定框基于视觉尺寸按比例缩放，居中偏移。这是雷电系列的核心设计哲学：玩家判定框极小(40%)，让玩家可以在密集弹幕间精准穿梭。",
    "hitboxRatios": {
      "player": 0.4,
      "enemy": 0.8,
      "playerBullet": 0.7,
      "enemyBullet": 0.7,
      "item": 1.2
    },
    "formula": {
      "description": "判定框计算公式",
      "hitboxWidth": "visualWidth * ratio",
      "hitboxHeight": "visualHeight * ratio",
      "offsetX": "(visualWidth - hitboxWidth) / 2",
      "offsetY": "(visualHeight - hitboxHeight) / 2",
      "hitboxX": "entity.x + offsetX",
      "hitboxY": "entity.y + offsetY",
      "note": "ratio > 1时offset为负数，判定框超出视觉范围（用于道具拾取）"
    },
    "designRationale": {
      "player_0_4": "雷电经典设计。玩家判定框仅为视觉的40%，使玩家可以在弹幕间精准穿梭，是弹幕游戏的核心体验。视觉上飞机看起来很大，但实际只有中心一小块会被击中。",
      "enemy_0_8": "敌机判定框略小于视觉，让玩家更容易击中敌人，提升射击手感。80%的比例在视觉合理性和打击感之间取得平衡。",
      "playerBullet_0_7": "玩家子弹判定框略小于视觉，避免'明明没碰到却判定击中'的不公平感，同时70%足够大不至于难以命中。",
      "enemyBullet_0_7": "敌机子弹判定框略小于视觉，给玩家微小容错空间。这是弹幕游戏的标配设计，配合玩家的40%判定框，形成'看起来很危险但实际有操作空间'的体验。",
      "item_1_2": "道具判定框大于视觉120%，方便拾取。正向反馈设计：玩家只需接近道具即可拾取，降低挫败感。"
    },
    "debugMode": {
      "description": "开发调试模式下可显示判定框边框，用于验证碰撞逻辑",
      "enabled": false,
      "playerHitboxColor": "rgba(0, 255, 0, 0.5)",
      "enemyHitboxColor": "rgba(255, 0, 0, 0.5)",
      "bulletHitboxColor": "rgba(255, 255, 0, 0.5)",
      "itemHitboxColor": "rgba(0, 255, 255, 0.5)"
    }
